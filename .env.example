# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=<SUPABASE_SERVICE_KEY>

# API Authentication (required for all /api/* endpoints)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET=

# Redis (optional — for distributed lock on iterate)
# Used to prevent concurrent iterate() calls across Vercel instances
REDIS_URL=redis://default:<password>@your-redis-instance:18906
ITERATE_LOCK_TTL_SECONDS=60

# Alpaca Trading (paper mode — credentials optional)
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=

# Alpaca Data API (required for data strategy price feeds)
ALPACA_DATA_API_KEY=
ALPACA_DATA_API_SECRET=

# Trading Loop Configuration
LOOP_SYMBOLS=BTC/USDT
LOOP_STRATEGY=ma_crossover
LOOP_INTERVAL_SECONDS=60
LOOP_POSITION_SIZE=0.1
LOOP_MAX_POSITIONS=1
LOOP_STOP_LOSS_PCT=2.0
LOOP_TAKE_PROFIT_PCT=4.0
LOOP_EXCHANGE=binance
LOOP_TIMEFRAME=1m
LOOP_FAST_MA=20
LOOP_SLOW_MA=50
LOOP_MODE=paper